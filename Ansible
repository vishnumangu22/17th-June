✅ STEP 9: Create Playbook
 
 
 
 
Shell
 
vi myplaybook.yml
``
Show more lines
 
👉 Paste:
 
 
 
 
YAML
 
---
- name: Install Apache and create file & directory
  hosts: ansiblegroup
  become: yes
 
  tasks:
 
    - name: Update apt cache
      ansible.builtin.apt:
        update_cache: yes
 
    - name: Install apache
      ansible.builtin.apt:
        name: apache2
        state: present
 
    - name: Create blank file
      ansible.builtin.file:
        path: /home/devops/myfile.txt
        state: touch
        mode: "0644"
 
    - name: Create directory
      ansible.builtin.file:
        path: /home/devops/mydir
        state: directory
        mode: "0755"
 
Show more lines
 
